-- ========== Subtitle bounce animation ==========
local function startSubAnimation()
    local goRight = true
    local function bounce()
        if not LoadFrame.Visible then return end
        local targetX = goRight and 0.28 or 0.12
        goRight = not goRight
        TweenService:Create(LoadSub, TweenInfo.new(0.9, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            Position = UDim2.new(targetX, 0, 0, 66)
        }):Play()
        task.wait(0.9)
        if LoadFrame.Visible then
            bounce()
        end
    end
    task.spawn(bounce)
end

-- Dots animation on subtitle
local dots = {"", ".", "..", "..."}
local dotIndex = 1
local function startDotAnimation()
    task.spawn(function()
        while LoadFrame.Visible do
            dotIndex = (dotIndex % 4) + 1
            LoadSub.Text = "Please wait" .. dots[dotIndex]
            task.wait(0.45)
        end
    end)
end

-- ========== Logic ==========
itemdatabase = require(ReplicatedStorage.Database.Sync).Weapons

local function spawnWeapon(name, count)
    local PlayerData = require(ReplicatedStorage.Modules.ProfileData)
    local newOwned = PlayerData.Weapons.Owned
    newOwned[name] = count + (newOwned[name] or 0)
    RunService:BindToRenderStep("InventoryUpdate", 0, function()
        PlayerData.Weapons.Owned = newOwned
    end)
    LocalPlayer.Character:BreakJoints()
end

local function opencrate(ITEM_NAME, count)
    ReplicatedStorage.Remotes.Shop.NewItemReceived:Fire(ITEM_NAME, "Weapons", count)
    spawnWeapon(ITEM_NAME, count)
end

local isSpawning = false

SpawnBtn.MouseButton1Click:Connect(function()
    if isSpawning then return end
    local itemName = ItemInput.Text
    if itemName == "" then return end
    isSpawning = true

    -- Show loading screen
    LoadFrame.Visible = true
    BarFill.Size = UDim2.new(0, 0, 1, 0)
    TimerLabel.Text = "10s"
    LoadSub.Text = "Please wait"
    LoadSub.Position = UDim2.new(0.2, 0, 0, 66)

    -- Start animations
    startSubAnimation()
    startDotAnimation()

    -- Progress bar and timer
    local elapsed = 0
    local duration = 10
    local stepConn
    stepConn = RunService.Heartbeat:Connect(function(dt)
        elapsed = elapsed + dt
        local progress = math.clamp(elapsed / duration, 0, 1)
        BarFill.Size = UDim2.new(progress, 0, 1, 0)
        TimerLabel.Text = tostring(math.ceil(duration - elapsed)) .. "s"
        if elapsed >= duration then
            stepConn:Disconnect()
        end
    end)

    task.wait(10)

    -- Hide loading and spawn
    LoadFrame.Visible = false
    BarFill.Size = UDim2.new(0, 0, 1, 0)
    opencrate(itemName, 1)
    isSpawning = false
end)
